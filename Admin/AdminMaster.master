</form>

<script>

    // ===== SIDEBAR TOGGLE =====
    const sidebar = document.querySelector(".sidebar");
    const body = document.body;

    document.getElementById("toggleSidebar").onclick = function () {
        sidebar.classList.toggle("collapsed");
        body.classList.toggle("collapsed-layout");

        localStorage.setItem("sidebar",
            sidebar.classList.contains("collapsed") ? "closed" : "open");
    };

    // Load state
    window.addEventListener("load", () => {
        if (localStorage.getItem("sidebar") === "closed") {
            sidebar.classList.add("collapsed");
            body.classList.add("collapsed-layout");
        }
    });

    // ===== SUBMENU =====
    function toggleMenu(el, menuId) {

        let menu = document.getElementById(menuId);

        document.querySelectorAll(".submenu").forEach(m => {
            if (m !== menu) m.classList.remove("show");
        });

        document.querySelectorAll(".arrow").forEach(a => {
            if (a !== el.querySelector(".arrow")) a.classList.remove("rotate");
        });

        menu.classList.toggle("show");
        el.querySelector(".arrow").classList.toggle("rotate");
    }

    // ===== ACTIVE MENU =====
    document.querySelectorAll(".sidebar a").forEach(link => {

        let href = link.getAttribute("href");

        if (href && window.location.pathname.toLowerCase().includes(href.toLowerCase())) {

            link.classList.add("active");

            let parent = link.closest(".submenu");
            if (parent) {
                parent.classList.add("show");

                let arrow = parent.previousElementSibling.querySelector(".arrow");
                if (arrow) arrow.classList.add("rotate");
            }
        }
    });

</script>
</body>
</html>