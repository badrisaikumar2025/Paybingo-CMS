}

.cpu{
background:linear-gradient(135deg,#3b82f6,#1e40af);
}

.ram{
background:linear-gradient(135deg,#22c55e,#166534);
}

.txn{
background:linear-gradient(135deg,#f97316,#c2410c);
}

.welcome{
    margin-right:auto; /* pushes everything else to right */
    font-weight:500;
}
</style>

</head>

<body>

