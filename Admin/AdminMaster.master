.live-feed{
overflow:hidden;
background:#0f172a;
border-radius:10px;
padding:10px 0;
position:relative;
}

.feed-track{
display:flex;
gap:40px;
white-space:nowrap;
animation:scrollFeed 20s linear infinite;
color:white;
font-size:14px;
padding-left:20px;
}

.feed-item{
display:flex;
align-items:center;
gap:10px;
}

.feed-success{
color:#22c55e;
font-weight:600;
}

.feed-failed{
color:#ef4444;
font-weight:600;
}

@keyframes scrollFeed{

0%{
transform:translateX(100%);
}

100%{
transform:translateX(-100%);
}

}

.live-feed{
overflow:hidden;
background:#0f172a;
border-radius:10px;
padding:12px 0;
position:relative;
height:40px;
display:flex;
align-items:center;
}

.feed-track{
display:flex;
gap:50px;
white-space:nowrap;
color:white;
font-size:14px;
padding-left:20px;
animation:scrollFeed 25s linear infinite;
}

.feed-item{
display:flex;
align-items:center;
gap:10px;
}

.feed-success{
color:#22c55e;
font-weight:600;
}

.feed-failed{
color:#ef4444;
font-weight:600;
}

@keyframes scrollFeed{

0%{
transform:translateX(0);
}

100%{
transform:translateX(-100%);
}

}
.sidebar-logo
{
